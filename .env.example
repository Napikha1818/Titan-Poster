# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_OWNER_ID=your_telegram_user_id

# Webhook URL (Cloud Run URL setelah deploy)
WEBHOOK_URL=https://your-cloud-run-url.run.app

# Google Cloud
GCP_PROJECT_ID=your_gcp_project_id

# YouTube OAuth2 (download dari GCP Console → APIs → Credentials)
YOUTUBE_CLIENT_SECRET_FILE=client_secret.json

# TikTok - ambil sessionid dari browser: F12 → Application → Cookies → tiktok.com → sessionid
TIKTOK_SESSION_ID=your_tiktok_session_id_here
TIKTOK_COOKIES_FILE=tiktok_cookies.txt
